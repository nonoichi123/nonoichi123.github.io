{
  "name": "nonopp-jp",
  "type": "module",
  "version": "1.0.0",
  "description": "ノノップ ポートフォリオサイト (Eleventy)",
  "scripts": {
    "build": "ELEVENTY_ENV=production npx @11ty/eleventy",
    "start": "npx @11ty/eleventy --serve",
    "clean": "rm -rf _site",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint:html": "html-validate --config .htmlvalidate.json \"_site/**/*.html\"",
    "test:content": "node --test test/**/*.test.js",
    "test": "npm run build && npm run lint:html && npm run test:content"
  },
  "devDependencies": {
    "@11ty/eleventy": "^3.0.0",
    "html-validate": "^9.0.0",
    "prettier": "^3.5.0",
    "prettier-plugin-jinja-template": "^2.0.0"
  }
}
